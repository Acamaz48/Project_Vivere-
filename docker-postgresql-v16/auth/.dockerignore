# =====================================================
# .dockerignore – AUTH DATABASE
# Arquivos e pastas ignorados no build da imagem
# =====================================================

# Dados persistentes (não devem entrar na imagem)
data/
**/data/

# Logs
*.log

# Arquivos temporários
*.tmp
*.swp

# Arquivos de sistema
.DS_Store
Thumbs.db

# Arquivos de ambiente (contêm senhas)
.env
.env.*