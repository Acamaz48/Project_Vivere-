# =====================================================
# VIVERE PLATFORM – LOGISTICS SERVICE
# Variáveis de ambiente (exemplo)
# =====================================================

# -----------------------------------------------------
# 1️⃣ APLICAÇÃO
# -----------------------------------------------------

# Ambiente de execução (development | production | test)
NODE_ENV=development

# Nome lógico do serviço (usado em logs e tracing)
SERVICE_NAME=logistics-service

# Porta interna onde a aplicação escuta
PORT=3000

# Habilita logs estruturados no formato JSON (true | false)
ENABLE_JSON_LOGS=false

# -----------------------------------------------------
# 2️⃣ BANCO DE DADOS (Docker Network)
# -----------------------------------------------------
# Esses valores são usados quando o serviço roda dentro da rede Docker.

DATABASE_HOST=logistics-db
DATABASE_PORT=5432
DATABASE_NAME=logistics_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# -----------------------------------------------------
# 3️⃣ STRINGS DE CONEXÃO
# -----------------------------------------------------

# Usada dentro dos containers Docker
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public

# Usada quando roda loc# =====================================================
# VIVERE PLATFORM – LOGISTICS SERVICE
# =====================================================

NODE_ENV=development
SERVICE_NAME=logistics-service
PORT=3000
ENABLE_JSON_LOGS=false

DATABASE_HOST=logistics-db
DATABASE_PORT=5432
DATABASE_NAME=logistics_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5435/logistics_db?schema=public

DB_WAIT_TIMEOUT=60
RUN_MIGRATIONS=true
RUN_POST_SQL=truelmente (fora do Docker)
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5435/logistics_db?schema=public

# -----------------------------------------------------
# 4️⃣ CONTROLE DE STARTUP
# -----------------------------------------------------

# Tempo máximo (em segundos) de espera pela disponibilidade do banco
DB_WAIT_TIMEOUT=60

# Habilita execução automática das migrações Prisma na subida do container
RUN_MIGRATIONS=true

# Habilita execução de script SQL complementar após as migrações (se existir)
RUN_POST_SQL=true