// =====================================================
// schema.prisma - Warehouse Service Database
// Domínio: Catálogo técnico, itens, BOM, templates de projeto
// Versão: 1.0
// =====================================================

generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/@warehouse/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enum para unidades de medida
enum Unit {
  m
  un
  m2
  kg
  dia
  kit
}

// Categorias de itens (hierárquicas)
model categories {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  parent    categories? @relation("category_hierarchy", fields: [parent_id], references: [id])
  parent_id String?   @db.Uuid

  // Filhos (categorias que têm esta como pai)
  children categories[] @relation("category_hierarchy")

  // Auditoria
  created_at DateTime @default(now()) @db.Timestamptz
  created_by String?  @db.Uuid
  updated_at DateTime @updatedAt @db.Timestamptz
  updated_by String?  @db.Uuid
  deleted_at DateTime? @db.Timestamptz

  // Relacionamentos
  items items[]

  @@map("categories")
  @@index([deleted_at])
}

// Itens do catálogo
model items {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku         String   // Código único (será índice parcial no script complementar)
  name        String
  unit        Unit     @map("unit") // Usando enum, no banco será TEXT com constraint CHECK
  width_mm    Decimal? @db.Decimal(18,6) @default(0)
  height_mm   Decimal? @db.Decimal(18,6) @default(0)
  length_mm   Decimal? @db.Decimal(18,6) @default(0)
  weight_kg   Decimal? @db.Decimal(18,6) @default(0)
  category    categories? @relation(fields: [category_id], references: [id])
  category_id String?   @db.Uuid
  is_active   Boolean   @default(true)

  // Auditoria
  created_at DateTime @default(now()) @db.Timestamptz
  created_by String?  @db.Uuid
  updated_at DateTime @updatedAt @db.Timestamptz
  updated_by String?  @db.Uuid
  deleted_at DateTime? @db.Timestamptz

  // Relacionamentos (BOM)
  parent_boms bom[] @relation("parent_item")
  child_boms  bom[] @relation("child_item")

  @@map("items")
  // Índice simples (parcial será criado via SQL)
  @@index([sku])
  @@index([deleted_at])
  @@index([category_id])
}

// Bill of Materials
model bom {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_item     items    @relation("parent_item", fields: [parent_item_id], references: [id])
  parent_item_id  String   @db.Uuid
  child_item      items    @relation("child_item", fields: [child_item_id], references: [id])
  child_item_id   String   @db.Uuid
  quantity        Decimal  @db.Decimal(18,6)
  is_optional     Boolean  @default(false)
  version_id      Int      @default(1)

  // Auditoria
  created_at DateTime @default(now()) @db.Timestamptz
  created_by String?  @db.Uuid
  updated_at DateTime @updatedAt @db.Timestamptz
  updated_by String?  @db.Uuid
  deleted_at DateTime? @db.Timestamptz

  @@map("bom")
  @@index([parent_item_id])
  @@index([child_item_id])
  @@index([deleted_at])
  @@unique([parent_item_id, child_item_id, version_id]) // Evita duplicatas da mesma versão
}