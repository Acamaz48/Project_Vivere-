# =====================================================
# VIVERE PLATFORM – AUTH SERVICE
# Variáveis de ambiente (exemplo)
# =====================================================

# -----------------------------------------------------
# 1️⃣ APLICAÇÃO
# -----------------------------------------------------
NODE_ENV=development
SERVICE_NAME=auth-service
PORT=3000
ENABLE_JSON_LOGS=false

# -----------------------------------------------------
# 2️⃣ BANCO DE DADOS (Docker Network)
# -----------------------------------------------------
DATABASE_HOST=auth-db
DATABASE_PORT=5432
DATABASE_NAME=auth_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# -----------------------------------------------------
# 3️⃣ STRINGS DE CONEXÃO
# -----------------------------------------------------
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public
DATABASE_URL_LOCAL=postgresql://postgres:postgres@localhost:5433/auth_db?schema=public

# -----------------------------------------------------
# 4️⃣ CONTROLE DE STARTUP
# -----------------------------------------------------
DB_WAIT_TIMEOUT=60
RUN_MIGRATIONS=true
RUN_POST_SQL=true