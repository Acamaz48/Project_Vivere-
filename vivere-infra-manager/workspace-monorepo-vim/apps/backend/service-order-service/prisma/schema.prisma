// =====================================================
// schema.prisma - Service Order Database
// Domínio: Ordens de serviço, propostas, faturamento
// Versão: 1.0
// =====================================================

generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/@service-order/prisma"
}

datasource db {
  provider = "postgresql"
}

// Tipos de cliente
enum CustomerType {
  ORGANIZATION
  PERSON
}

// Status da OS (pode ser expandido conforme necessidade)
enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Cabeçalho da OS
model orders {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String   // Número da OS (será transformado em índice parcial no script complementar)
  customer_type CustomerType
  customer_id String   @db.Uuid // ID em organizations ou persons (identity_db)
  status     OrderStatus @default(DRAFT)
  total_value Decimal? @db.Decimal(18,6) @default(0)
  currency   String   @default("BRL")
  notes      String?

  // Campos específicos da OS
  event_name           String?
  event_location       String?
  event_start          DateTime? @db.Timestamptz
  event_end            DateTime? @db.Timestamptz
  assembly_start       DateTime? @db.Timestamptz
  assembly_deadline    DateTime? @db.Timestamptz
  disassembly_start    DateTime? @db.Timestamptz
  onsite_responsible_name String?
  notes_montagem       String?

  // Auditoria
  created_at DateTime @default(now()) @db.Timestamptz
  created_by String  @db.Uuid // Vendedor / responsável
  updated_at DateTime @updatedAt @db.Timestamptz
  updated_by String? @db.Uuid
  deleted_at DateTime? @db.Timestamptz

  // Relacionamentos
  items order_items[]

  @@map("orders")
  @@unique([code]) // Será recriado como índice parcial no script complementar
  // Índices simples (parciais serão criados via SQL)
  @@index([customer_type, customer_id])
  @@index([deleted_at])
}

// Itens da OS (próprios ou de terceiros)
model order_items {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order      orders   @relation(fields: [order_id], references: [id])
  order_id   String   @db.Uuid

  // Item próprio (warehouse_db)
  item_id    String?  @db.Uuid

  // Item de terceiro
  supplier_id          String?  @db.Uuid // Ref. organizations (identity_db)
  supplier_item_description String?
  supplier_order_ref   String?
  cost_price           Decimal? @db.Decimal(18,6) // Custo (para margem)

  quantity        Decimal @db.Decimal(18,6)
  daily_unit_price Decimal @db.Decimal(18,6) // Preço por unidade por dia
  number_of_days  Int
  discount        Decimal @db.Decimal(18,6) @default(0)

  period_start    DateTime @db.Timestamptz
  period_end      DateTime @db.Timestamptz

  notes           String?

  // Auditoria
  created_at DateTime @default(now()) @db.Timestamptz
  created_by String? @db.Uuid
  updated_at DateTime @updatedAt @db.Timestamptz
  updated_by String? @db.Uuid
  deleted_at DateTime? @db.Timestamptz

  @@map("order_items")
  @@index([order_id])
  @@index([supplier_id])
  @@index([deleted_at])
  // As validações de item_id/supplier_id serão feitas no service, não via check
}