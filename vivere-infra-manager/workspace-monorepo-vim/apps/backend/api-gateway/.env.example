# =====================================================
# VIVERE PLATFORM – API GATEWAY
# Variáveis de ambiente (exemplo)
# =====================================================

# -----------------------------------------------------
# 1️⃣ APLICAÇÃO
# -----------------------------------------------------
NODE_ENV=development
SERVICE_NAME=api-gateway
PORT=3000
ENABLE_JSON_LOGS=false

# -----------------------------------------------------
# 2️⃣ ROTEAMENTO DOS MICROSSERVIÇOS (Docker Network)
# -----------------------------------------------------
IDENTITY_SERVICE_URL=http://identity-service:3000
AUTH_SERVICE_URL=http://auth-service:3000
WAREHOUSE_SERVICE_URL=http://warehouse-service:3000
SERVICE_ORDER_SERVICE_URL=http://service-order-service:3000
LOGISTICS_SERVICE_URL=http://logistics-service:3000

# -----------------------------------------------------
# 3️⃣ CONTROLE DE STARTUP (OPCIONAL)
# -----------------------------------------------------
WAIT_FOR_SERVICES=false
SERVICES_WAIT_TIMEOUT=60