# ============================================================
# VIVERE PLATFORM – PostgreSQL Multi-Database Configuration
# ============================================================
#
# Este arquivo é usado pelo docker-compose para configurar todos os bancos.
# As variáveis são passadas para os containers via environment e command.
#
# ============================================================

# ========================
# Credenciais principais
# ========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Ambiente: development | staging | production
# Define qual subpasta de dados será usada e qual seed será executado
SEED_ENV=development

# Encoding e locale (padrão para novos bancos)
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C.UTF-8

# Timezone
TZ=UTC
PGTZ=UTC

# ========================
# Ajustes de performance
# ========================
# Esses valores são passados como parâmetros de linha de comando para o PostgreSQL
# via 'command' no docker-compose. Ajuste conforme a capacidade do host.

# Memória compartilhada para cache de dados
POSTGRES_SHARED_BUFFERS=256MB

# Memória para operações de ordenação e hash (por operação)
POSTGRES_WORK_MEM=16MB

# Memória para tarefas de manutenção (VACUUM, CREATE INDEX)
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# Número máximo de conexões simultâneas
POSTGRES_MAX_CONNECTIONS=200

# Buffer para Write-Ahead Log (WAL)
POSTGRES_WAL_BUFFERS=16MB

# ========================
# Logging (opcional)
# ========================
# Define quais statements são logados (none, ddl, mod, all)
POSTGRES_LOG_STATEMENT=none

# Log de queries mais lentas que este valor (ms)
POSTGRES_LOG_MIN_DURATION_STATEMENT=500ms

# ========================
# Segurança (autenticação)
# ========================
# Método de autenticação para conexões locais (md5, scram-sha-256, trust)
POSTGRES_HOST_AUTH_METHOD=md5