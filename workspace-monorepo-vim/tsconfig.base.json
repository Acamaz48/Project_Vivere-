{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "ignoreDeprecations": "5.0",
    "baseUrl": "./",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "paths": {
      "@auth/prisma": ["node_modules/@auth/prisma"],
      "@identity/prisma": ["node_modules/@identity/prisma"],
      "@workspace-monorepo-vim/contracts": ["libs/shared/contracts/src/index.ts"],
      "@workspace-monorepo-vim/domain": ["libs/shared/domain/src/index.ts"],
      "@workspace-monorepo-vim/events": ["libs/shared/events/src/index.ts"],
      "@workspace-monorepo-vim/inventory-domain": ["libs/backend/inventory-domain/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}